{
  "version": 2,
  "framework": null,
  "installCommand": "cd turnos-psicologo && npm install",
  "buildCommand": "cd turnos-psicologo && npm run vercel-build",
  "outputDirectory": "turnos-psicologo/dist/turnos-psicologo/browser",
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
